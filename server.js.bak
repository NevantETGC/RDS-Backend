// PATCH /alarm/:id/notes — FD adds notes
app.patch('/alarm/:id/notes', async (req, res) => {
  const { notes } = req.body;
  try {
    const r = await pool.query(
      "UPDATE fire_alarms SET notes = $1, last_updated = NOW() WHERE id = $2 RETURNING *",
      [notes || '', req.params.id]
    );
    res.json(r.rows[0]);
  } catch (err) { res.status(500).json({ error: err.message }); }
});

// GET /alarm-notifications/:dept — unread alarm notifications
app.get('/alarm-notifications/:dept', async (req, res) => {
  try {
    const r = await pool.query(
      `SELECT an.*, fa.sim_code, fa.parcel_code, fa.region, fa.alarm_type,
              fa.fire_count, fa.smoke_count, fa.ladder_triggered, fa.first_detected
       FROM alarm_notifications an
       JOIN fire_alarms fa ON an.alarm_id = fa.id
       WHERE an.department = $1 AND an.seen = false
       ORDER BY an.created_at DESC`,
      [req.params.dept]
    );
    res.json(r.rows);
  } catch (err) { res.status(500).json({ error: err.message }); }
});

// PATCH /alarm-notifications/:dept/seen — mark all seen
app.patch('/alarm-notifications/:dept/seen', async (req, res) => {
  try {
    await pool.query('UPDATE alarm_notifications SET seen = true WHERE department = $1', [req.params.dept]);
    res.json({ ok: true });
  } catch (err) { res.status(500).json({ error: err.message }); }
});

app.listen(3000, () => console.log('Hydrant API v4 running on port 3000'));
